# Secrets for the orchestrator daemon (README §3.3 Layer 5).
# Copy to `.env` and fill in. Never commit `.env`. These are read from the
# environment; they are never stored in SQLite.

# GitHub token used by the Git/GitHub adapter (issues, PRs, branches, comments).
GITHUB_TOKEN=

# Anthropic API key consumed by the Claude Code harness the agents run inside (the
# Stage Executor shells out to the CLI; we never call the model API directly).
ANTHROPIC_API_KEY=
