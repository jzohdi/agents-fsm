# Secrets for the orchestrator daemon (README §3.3 Layer 5).
# Copy to `.env` and fill in. Never commit `.env`. These are read from the
# environment; they are never stored in SQLite.

# GitHub token used by the Git/GitHub adapter (issues, PRs, branches, comments).
GITHUB_TOKEN=

# Anthropic API key consumed by the Claude Code harness (default) the agents run inside
# (the Stage Executor shells out to the CLI; we never call the model API directly).
# Alternatively authenticate the CLI once with `claude login`.
ANTHROPIC_API_KEY=

# Optional — only needed if you run the Cursor harness (README §9.8). Consumed by the
# `cursor-agent` CLI. Alternatively authenticate it once with `cursor-agent login`.
CURSOR_API_KEY=
